#include <iostream>
#include "Core.h"
#include "Carriers.h"
#include "Manager.h"

using namespace std;

int main() {

    int choice;

    do {
        cout << "\n===== Systeme de Livraison =====" << endl;
        cout << "1. Ajouter une livraison" << endl;
        cout << "2. Afficher les livraisons" << endl;
        cout << "3. Gerer le systeme" << endl;
        cout << "0. Quitter" << endl;

        cout << "Votre choix : ";
        cin >> choice;

        switch(choice) {

        case 1:
            cout << "Ajout..." << endl;
            break;

        case 2:
            cout << "Affichage..." << endl;
            break;

        case 3:
            cout << "Gestion..." << endl;
            break;

        case 0:
            cout << "Programme ferme." << endl;
            break;

        default:
            cout << "Choix invalide !" << endl;
        }

    } while(choice != 0);

    return 0;
}
